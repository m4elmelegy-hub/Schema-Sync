# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://erpuser:change_this_password@localhost:5432/erp
DB_PASSWORD=change_this_password

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=another_long_random_string_for_refresh_tokens

# TOTP Encryption key — must be exactly 32 characters (AES-256-CBC)
TOTP_ENCRYPTION_KEY=32_char_encryption_key_for_totp_s

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Leave empty to allow all origins (not recommended for production)
ALLOWED_ORIGINS=https://yourdomain.com

# ── Frontend Static Files (optional) ─────────────────────────────────────────
# Override the path to the built frontend. Defaults to ../../erp-system/dist/public
# relative to the backend dist directory.
# FRONTEND_DIST=/var/www/erp/artifacts/erp-system/dist/public

# ── Optional: IP Restriction for Super Admin ─────────────────────────────────
# Comma-separated IPs allowed to access super admin routes. Empty = allow all.
# SUPER_ADMIN_IPS=1.2.3.4,5.6.7.8

# ── Optional: Backup directory ────────────────────────────────────────────────
BACKUP_DIR=/root/db-backups
